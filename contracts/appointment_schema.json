{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "appointment schema",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "createdAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["active", "inactive"] }
  },
  "required": ["id"]
}
